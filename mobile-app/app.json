{
  "expo": {
    "name": "عليقة - Alieqa",
    "slug": "aleqa",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "alieqa",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D4F"
    },
    "newArchEnabled": false,
    "android": {
      "package": "app.alieqa.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2E7D4F"
      },
      "permissions": ["INTERNET", "VIBRATE", "POST_NOTIFICATIONS"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5987c9e9-1ec3-4c7d-a064-42b1c1a7b8ce"
      },
      "appUrl": "https://alieqa.vercel.app"
    },
    "owner": "osadevs-team"
  }
}
